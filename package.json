{
  "name": "@mindmatrix/junk-engine",
  "version": "0.0.1",
  "description": "JunkEngine - A scrappy hacky game engine that gets the job done (mostly).",
  "main": "dist/engine/index.js",
  "types": "dist/engine/index.d.ts",
  "files": [
    "dist/engine/**/*"
  ],
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development",
    "start": "webpack serve --mode development --open",
    "clean": "rm -rf dist",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "size": "node scripts/check-bundle-size.mjs",
    "size:update": "node scripts/check-bundle-size.mjs --update"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@webgpu/types": "^0.1.69",
    "copy-webpack-plugin": "^14.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "html-webpack-plugin": "^5.5.0",
    "terser-webpack-plugin": "^5.3.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "webpack": "^5.80.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.2.3"
  },
  "keywords": [
    "webpack",
    "typescript",
    "canvas",
    "terser",
    "engine"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
